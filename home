<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Курс по Умному Дому - Профессиональное обучение</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            background: #ffffff;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #1a1a1a 0%, #000000 50%, #1a1a1a 100%);
            color: #ffffff;
            padding: 5rem 0;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, #3125c0, #b6324d);
            opacity: 0.2;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .hero-badge {
            display: inline-block;
            background: #3125c0;
            color: #ffffff;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 1.5rem;
        }

        .hero-gradient {
            background: linear-gradient(90deg, #3125c0, #b6324d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.25rem;
            color: #cccccc;
            margin-bottom: 2rem;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 1rem 2rem;
            border-radius: 0.5rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
            cursor: pointer;
            border: none;
            font-size: 1rem;
        }

        .btn-primary {
            background: #3125c0;
            color: #ffffff;
        }

        .btn-primary:hover {
            background: #2819a0;
            box-shadow: 0 10px 25px rgba(49, 37, 192, 0.3);
        }

        .btn-secondary {
            background: #ffffff;
            color: #000000;
        }

        .btn-secondary:hover {
            background: #f0f0f0;
        }

        .hero-image {
            aspect-ratio: 1;
            border-radius: 1rem;
            overflow: hidden;
            border: 4px solid #3125c0;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .hero-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Stats Section */
        .stats {
            background: #000000;
            color: #ffffff;
            padding: 3rem 0;
            border-top: 1px solid #333;
            border-bottom: 1px solid #333;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            text-align: center;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .stat-number.color-1 {
            color: #3125c0;
        }

        .stat-number.color-2 {
            color: #b6324d;
        }

        .stat-label {
            color: #999;
            font-size: 0.875rem;
        }

        /* Benefits Section */
        .benefits {
            padding: 5rem 0;
            background: #f9f9f9;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-header h2 {
            font-size: 2.5rem;
            font-weight: 700;
            color: #000000;
            margin-bottom: 1rem;
        }

        .section-header p {
            font-size: 1.125rem;
            color: #666;
            max-width: 600px;
            margin: 0 auto;
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .benefit-card {
            background: #ffffff;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            transition: all 0.3s;
        }

        .benefit-card:hover {
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
            transform: translateY(-5px);
        }

        .benefit-icon {
            width: 4rem;
            height: 4rem;
            background: linear-gradient(135deg, #3125c0, #b6324d);
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .benefit-icon svg {
            width: 2rem;
            height: 2rem;
            color: #ffffff;
        }

        .benefit-card h3 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #000000;
            margin-bottom: 0.75rem;
        }

        .benefit-card p {
            color: #666;
        }

        /* Packages Section */
        .packages {
            padding: 5rem 0;
            background: #ffffff;
        }

        .packages-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .package-card {
            background: #ffffff;
            border-radius: 1.5rem;
            overflow: hidden;
            border: 2px solid #e0e0e0;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s;
        }

        .package-card:hover {
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
            transform: scale(1.05);
        }

        .package-card.popular {
            border-color: #b6324d;
        }

        .popular-badge {
            background: #b6324d;
            color: #ffffff;
            text-align: center;
            padding: 0.5rem 1rem;
            font-weight: 600;
            font-size: 0.875rem;
        }

        .package-image {
            height: 200px;
            overflow: hidden;
        }

        .package-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .package-content {
            padding: 2rem;
        }

        .package-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .package-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .package-icon svg {
            width: 1.5rem;
            height: 1.5rem;
            color: #ffffff;
        }

        .package-title h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #000000;
        }

        .package-title p {
            font-size: 0.875rem;
            color: #666;
        }

        .package-price {
            margin-bottom: 1.5rem;
        }

        .package-price .price {
            font-size: 2.5rem;
            font-weight: 700;
            color: #000000;
        }

        .package-price .period {
            color: #666;
            font-size: 0.875rem;
        }

        .package-features {
            list-style: none;
            margin-bottom: 2rem;
        }

        .package-features li {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
            color: #333;
        }

        .package-features li svg {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
            margin-top: 0.125rem;
        }

        /* Bundle Offer */
        .bundle-offer {
            margin-top: 3rem;
            background: linear-gradient(90deg, #000000, #1a1a1a, #000000);
            border-radius: 1.5rem;
            padding: 3rem;
            text-align: center;
            color: #ffffff;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .bundle-offer h3 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .bundle-offer p {
            font-size: 1.25rem;
            color: #cccccc;
            margin-bottom: 1.5rem;
        }

        .bundle-pricing {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .old-price {
            font-size: 1.5rem;
            color: #999;
            text-decoration: line-through;
        }

        .new-price {
            font-size: 3rem;
            font-weight: 700;
            background: linear-gradient(90deg, #3125c0, #b6324d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .savings-badge {
            display: inline-block;
            background: #b6324d;
            color: #ffffff;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .btn-gradient {
            background: linear-gradient(90deg, #3125c0, #b6324d);
            color: #ffffff;
            font-size: 1.125rem;
        }

        .btn-gradient:hover {
            box-shadow: 0 10px 30px rgba(49, 37, 192, 0.5);
        }

        /* CTA Section */
        .cta {
            background: linear-gradient(135deg, #3125c0, #b6324d);
            padding: 5rem 0;
            color: #ffffff;
        }

        .cta-content {
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .cta h2 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .cta p {
            font-size: 1.25rem;
            margin-bottom: 2rem;
            opacity: 0.95;
        }

        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-white {
            background: #ffffff;
            color: #3125c0;
        }

        .btn-white:hover {
            background: #f0f0f0;
        }

        .btn-black {
            background: #000000;
            color: #ffffff;
        }

        .btn-black:hover {
            background: #1a1a1a;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #ffffff;
            border-radius: 1.5rem;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            margin-bottom: 1.5rem;
        }

        .modal-header h3 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #000000;
            margin-bottom: 0.5rem;
        }

        .modal-header p {
            color: #666;
        }

        .modal-header p strong {
            color: #000000;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group input {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid #e0e0e0;
            border-radius: 0.5rem;
            font-size: 1rem;
            transition: border-color 0.3s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #3125c0;
        }

        .modal-buttons {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .btn-close {
            background: transparent;
            color: #666;
            border: none;
            padding: 0.75rem;
        }

        .btn-close:hover {
            color: #000000;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .hero-content {
                grid-template-columns: 1fr;
            }

            .hero h1 {
                font-size: 2.5rem;
            }

            .packages-grid,
            .benefits-grid {
                grid-template-columns: 1fr;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .hero {
                padding: 3rem 0;
            }

            .hero h1 {
                font-size: 2rem;
            }

            .hero p {
                font-size: 1rem;
            }

            .hero-buttons {
                flex-direction: column;
            }

            .section-header h2 {
                font-size: 2rem;
            }

            .stat-number {
                font-size: 2rem;
            }

            .bundle-offer h3 {
                font-size: 1.75rem;
            }

            .new-price {
                font-size: 2rem;
            }

            .cta h2 {
                font-size: 1.75rem;
            }
        }
    </style>
</head>
